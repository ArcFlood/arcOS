# ARC-Memory Environment Configuration
# Copy this file to .env and fill in your values

# Path to Obsidian vault containing AI chat .md files
VAULT_PATH=/Users/noahpowell/ArcVault/AIChats

# Path for LanceDB storage
LANCEDB_PATH=~/.noah-ai-hub/memory/lancedb

# Ollama base URL (default for local install)
OLLAMA_URL=http://localhost:11434

# Embedding model (must be pulled via: ollama pull nomic-embed-text)
EMBEDDING_MODEL=nomic-embed-text

# MCP server port
MCP_PORT=8082
